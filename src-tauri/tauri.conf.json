{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MacroSpend Tracker",
  "version": "0.1.0",
  "identifier": "com.macrospend.tracker",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MacroSpend Tracker",
        "width": 360,
        "height": 280,
        "resizable": false,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://esm.sh; style-src 'self' 'unsafe-inline'; connect-src 'self' https://bhluusqyqetongajeprh.supabase.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "app"],
    "category": "Productivity",
    "shortDescription": "MacroSpend desktop tracker",
    "longDescription": "Privacy-first software usage tracker. Captures only active app name and window title.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "bhluusqyqetongajeprh.supabase.co"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/REPLACE_ORG/macrospend-tracker/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "REPLACE_WITH_OUTPUT_OF_npm_run_tauri_signer_generate"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["macrospend"]
      }
    },
    "autostart": {
      "macosLogin": true
    }
  }
}
